# ── DATABASE ────────────────────────────────────────────────────────────────
# Neon PostgreSQL — https://neon.tech (free tier: 512 MB)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── APP ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── ABLY REALTIME ───────────────────────────────────────────────────────────
# https://ably.com — free tier: 6M messages/month
# Use the ROOT API key here (server-side only, never exposed to client)
ABLY_API_KEY=your_root_ably_api_key_here

# ── ANALYTICS (optional) ────────────────────────────────────────────────────
# Plausible — privacy-first analytics, no cookies
# https://plausible.io — set to your domain e.g. "raisy.app"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── SECURITY ────────────────────────────────────────────────────────────────
# Salt for IP hashing (generate a random string, keep secret)
IP_SALT=change-me-to-something-random-and-secret
